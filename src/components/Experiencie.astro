---
const experiencies = [
  {
    puesto: "Analyst Programmer",
    nombre: "BioBoxMed",
    link: "https://bioboxmed.com/site/",
    logro: [
      "Design and planning of functionalities.",
      "Time estimation and priority on tickets.",
      "Accessibility analysis of applications.",
    ],
    techStack: [
      "React Js",
      "Jira",
      "GitLab",
      "Gitflow"
    ],
    estado: " 2025 Aug. - Currently working here 👈🏻",
  },
  {
    puesto: "Frontend Developer",
    nombre: "BioBoxMed",
    link: "https://bioboxmed.com/site/",
    logro: [
      "Design and development of a web application designed to monitor and manage studies performed at partner clinics.",
      "Maintenance and customize third-party applications to meet company needs.",
    ],
    techStack: [
      "React Js",
      "Redux Toolkit",
      "Material UI",
      "Vitest",
      "Cypress",
      "React-Testing-Library",
    ],
    estado: "2023 Oct. - 2025 Aug.",
  },
  {
    puesto: "Frontend Developer",
    link: "https://entre-copas.vercel.app/",
    nombre: "Entre Copas",
    logro: [
      "Application deploy on Vercel.",
      "Maintenance and fixing application for people-groups",
    ],
    techStack: ["React Js"],
    estado: "Finished",
  },
];
---

<div class="text-center mx-10 sm:mx-24">
  <h2 class="text-3xl my-10">My experiencie</h2>
  {
    experiencies.map((experiencia) => {
      return (
        <div class="m-auto border-2 border-violet-800 rounded-2xl my-5 text-start p-8 max-w-300">
          <p class="font-bold text-lg text-violet-500 mb-2">
            {experiencia.puesto}
          </p>
          <p>{experiencia.nombre}</p>
          {experiencia.link && (
            <a href={experiencia.link} target="_blank">
              Visit <span class="text-violet-500">{experiencia.nombre}</span>
            </a>
          )}

          <div class="mt-3 pt-3 border-violet-50 border-t-2">
            {experiencia.logro?.map((logro) => {
              return <li class=""> {logro}</li>;
            })}
          </div>
          <div class="flex flex-wrap">
            {experiencia.techStack?.map((tech) => {
              return <span class="text-violet-500 mx-3">{tech}</span>;
            })}
          </div>

          <p class="font-thin">{experiencia.estado}</p>
        </div>
      );
    })
  }
</div>
